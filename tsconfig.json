{
  "include": [
    "./src"
  ],
  "compilerOptions": {
    "target": "ESNext",
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "skipLibCheck": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "outDir": "types/generated"
  }
}